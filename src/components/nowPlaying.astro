<p>Now playing:</p>
<div id="nowPlayingWidget">
    <img id="art" alt="" />
    <div id="npText">
        <div id="liveRow">
            <span id="liveBadge">🔴 LIVE</span>
            <span id="djName"></span>
        </div>
        <div id="track">Loading…</div>
        <div id="listeners"></div>
    </div>
</div>

<script>
    const initNowPlaying = () => {
        const NOW_PLAYING_URL =
            'https://stream.jettyradio.com/api/nowplaying_static/jettyradio.json'

        const artEl = document.getElementById('art') as HTMLImageElement
        const trackEl = document.getElementById('track') as HTMLElement
        const listenersEl = document.getElementById('listeners') as HTMLElement
        const liveBadgeEl = document.getElementById('liveBadge') as HTMLElement
        const djNameEl = document.getElementById('djName') as HTMLElement

        async function updateNowPlaying() {
            if (!artEl || !trackEl || !listenersEl || !liveBadgeEl || !djNameEl)
                return 0
            try {
                const res = await fetch(NOW_PLAYING_URL, { cache: 'no-store' })
                const data = await res.json()

                /* track info */
                const song = data.now_playing?.song
                if (song) {
                    trackEl.textContent = `${song.artist} — ${song.title}`
                } else {
                    trackEl.textContent = 'Off air'
                }

                /* album art */
                if (song?.art) {
                    artEl.src = song.art
                    artEl.style.display = 'block'
                } else {
                    artEl.style.display = 'none'
                }

                /* listeners */
                const listeners = data.listeners?.current
                listenersEl.textContent =
                    typeof listeners === 'number'
                        ? listeners === 1
                            ? '1 listener'
                            : `${listeners} listeners`
                        : ''

                /* live status */
                if (data.live?.is_live) {
                    liveBadgeEl.style.display = 'inline'
                    djNameEl.textContent = data.live.streamer_name
                        ? data.live.streamer_name
                        : 'Live DJ'
                } else {
                    liveBadgeEl.style.display = 'none'
                    djNameEl.textContent = ''
                }
            } catch (e) {
                trackEl.textContent = 'Unable to load now playing'
                listenersEl.textContent = ''
                artEl.style.display = 'none'
                liveBadgeEl.style.display = 'none'
                djNameEl.textContent = ''
            }
        }

        updateNowPlaying()
        const intervalId = setInterval(updateNowPlaying, 3000)
        return intervalId
    }
    let id = initNowPlaying()
    document.addEventListener('astro:before-swap', () => {
        clearInterval(id)
    })
    document.addEventListener('astro:page-load', () => (id = initNowPlaying()))
</script>
