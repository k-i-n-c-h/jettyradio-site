---

<canvas id="spectrum" transition:persist></canvas>
<button id="playBtn" transition:persist>▶ LIVE</button>

<!-- Hidden audio element -->
<audio
    id="audio"
    src="https://stream.jettyradio.com/listen/jettyradio/radio.mp3"
    crossorigin="anonymous"
    playsinline
    transition:persist></audio>

<script>
    const audio = document.getElementById('audio') as HTMLAudioElement
    const canvas = document.getElementById('spectrum') as HTMLCanvasElement
    const ctx = canvas.getContext('2d')
    const playBtn = document.getElementById('playBtn') as HTMLElement

    const HEIGHT = 50
    canvas.height = HEIGHT

    let audioCtx: AudioContext | null = null
    let analyser: AnalyserNode | null = null
    let dataArray: Uint8Array<ArrayBuffer> | null = null
    let started = false

    function initAudio() {
        if (started) return
        const AudioContextClass =
            window.AudioContext || (window as any).webkitAudioContext
        audioCtx = new AudioContextClass()
        analyser = audioCtx.createAnalyser()
        const bufferLength = analyser.frequencyBinCount
        dataArray = new Uint8Array(bufferLength)

        const sourceNode = audioCtx.createMediaElementSource(audio)
        sourceNode.connect(analyser)
        analyser.connect(audioCtx.destination)

        canvas.width = bufferLength
        draw()
        started = true
    }

    function draw() {
        if (!analyser || !ctx || !dataArray) return

        requestAnimationFrame(draw)
        analyser.getByteFrequencyData(dataArray)
        ctx.clearRect(0, 0, canvas.width, HEIGHT)

        for (let i = 0; i < dataArray.length; i++) {
            const v = dataArray[i] / 255
            const h = Math.floor(v * HEIGHT)
            ctx.fillStyle = '#f2f2f2'
            ctx.fillRect(i, HEIGHT - h, 1, h)
        }
    }

    async function togglePlay() {
        initAudio()

        if (!audioCtx) return

        if (audioCtx.state !== 'running') {
            await audioCtx.resume()
        }
        if (audio.paused) {
            audio.muted = true
            try {
                await audio.play()
                setTimeout(() => {
                    audio.muted = false
                }, 100)
                playBtn.textContent = '❚❚ LIVE'
            } catch (e) {
                console.error('Playback failed:', e)
            }
        } else {
            audio.pause()
            playBtn.textContent = '▶ LIVE'
        }
    }

    playBtn.addEventListener('click', togglePlay)
    canvas.addEventListener('click', togglePlay)
</script>
