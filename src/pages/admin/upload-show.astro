---
import { keyBy } from 'es-toolkit/array'
import AdminLayout from '../../layouts/admin-layout.astro'
import { getCalendarEvents } from '../../lib/google/calendar-events'
import { getShowsFromSheet } from '../../lib/google/regular-shows'
import { getPlaylists } from '../../lib/azuracast/get-playlists'
import { Icon } from 'astro-icon/components'
const events = await getCalendarEvents()
const eventsById = keyBy(events, (event) => event.id)
const shows = await getShowsFromSheet()
const playlists = await getPlaylists()
---

<AdminLayout>
    <form id="upload-form">
        <label for="show-title">Playlist:</label>
        <select name="playlist" id="playlist">
            {
                playlists.map((playlist) => (
                    <option value={playlist.id}>{playlist.name}</option>
                ))
            }
        </select>
        <div>
            <label for="show-title">Show title:</label>
            <input
                type="text"
                name="showTitle"
                id="show-title"
                placeholder="Show title"
            />
        </div>

        <div>
            <label for="air-date">Air date:</label>
            <input type="date" name="airDate" id="air-date" />
        </div>
        <div>
            <label for="setlist">Setlist:</label>
            <textarea name="setlist" id="setlist"></textarea>
        </div>
        <input type="file" id="file" accept="audio/mpeg" />
        <button type="submit">Upload</button>
        <progress id="progress" value="0" max="100" hidden></progress>
        <p id="status"></p>
    </form>
    <Icon name="bubble-loading" style="fill: white;" />
    <script>
        import Flow from '@flowjs/flow.js'

        const stationId = 1
        const apiKey = '10a1c793f951002f:bc4001e0071666d67fc8a6893288c6d8'

        const progress = document.getElementById(
            'progress',
        ) as HTMLProgressElement
        const status = document.getElementById('status') as HTMLElement

        const flow = new Flow({
            target: `https://stream.jettyradio.com/api/station/${stationId}/files/upload`,
            headers: { 'X-API-Key': apiKey },
            chunkSize: 1 * 1024 * 1024, // 1MB chunks
            simultaneousUploads: 1, // sequential, safer for ordered reassembly
            testChunks: false, // AzuraCast doesn't implement the GET test endpoint
            permanentErrors: [400, 404, 415, 500, 501],
            query: {
                currentDirectory: '', // root of media library
            },
        })
        const fileElement = document.getElementById('file')
        flow.assignBrowse(fileElement ? [fileElement] : [])

        flow.on('fileAdded', (file) => {
            status.textContent = `File selected: ${file.name} (${(file.size / 1024 / 1024).toFixed(1)} MB)`
        })

        flow.on('fileProgress', (file) => {
            const pct = Math.round(file.progress() * 100)
            progress.hidden = false
            progress.value = pct
            status.textContent = `Uploading… ${pct}%`
        })

        flow.on('fileSuccess', () => {
            status.textContent = 'Upload complete!'
        })

        flow.on('fileError', (file, message) => {
            status.textContent = `Upload failed: ${message}`
        })
        document
            .getElementById('upload-form')
            ?.addEventListener('submit', (e) => {
                e.preventDefault()
                if (flow.files.length === 0) {
                    status.textContent = 'Please select a file first.'
                    return
                }
                flow.upload()
            })
    </script>
</AdminLayout>

<script define:vars={{ eventsById }}>
    const params = new URLSearchParams(window.location.search)
    const eventId = params.get('event-id')
    const event = eventsById[eventId]
    if (event) {
    }
</script>
